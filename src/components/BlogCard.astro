---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
---

<article class:list={['blog-card', { 'blog-card--featured': featured }]}>
  <div class="blog-card__meta">
    <span>{post.data.category}</span>
    <span>{post.data.readingTime}</span>
  </div>
  <h3><a href={`/blog/${post.data.slug}/`}>{post.data.title}</a></h3>
  <p class="muted">{post.data.summary}</p>
  <a class="service-card__action" href={`/blog/${post.data.slug}/`}>Leer guia</a>
</article>
