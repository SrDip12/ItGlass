---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { localBusinessSchema } from '../../utils/schema';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Servicios ItGlass | PVC, termopanel, aluminio y vidrio"
  description="Servicios de vidrieria, termopaneles, ventanas PVC, aluminio y shower doors para viviendas y ampliaciones en Santiago Norte."
  schema={localBusinessSchema}
>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">Servicios</p>
        <h1>Soluciones de vidrio explicadas con criterio.</h1>
        <p class="lede">Elige segun problema: frio, calor, ruido, presupuesto, orientacion y uso diario de la ventana o cierre.</p>
      </div>
    </section>
    <section class="section">
      <div class="container">
        <div class="service-grid">
          {services.map((service) => <ServiceCard service={service} />)}
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppButton />
</BaseLayout>
