---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrustStrip from '../components/TrustStrip.astro';
import ServiceCard from '../components/ServiceCard.astro';
import WorkCard from '../components/WorkCard.astro';
import BlogCard from '../components/BlogCard.astro';
import FAQList from '../components/FAQList.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import CoverageMap from '../components/CoverageMap.astro';
import { contact } from '../data/site';
import { localBusinessSchema } from '../utils/schema';
import { whatsappHref } from '../utils/whatsapp';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const works = (await getCollection('works')).sort((a, b) => a.data.order - b.data.order).slice(0, 3);
const posts = (await getCollection('blog')).sort((a, b) => a.data.order - b.data.order).slice(0, 3);
const faqs = (await getCollection('faqs')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);
const title = 'ItGlass | Termopaneles y ventanas PVC en toda la RM';
const description = 'Instalacion garantizada de termopaneles, ventanas PVC, aluminio y vidrios en toda la Region Metropolitana. Fuera de la RM se conversa.';
---

<BaseLayout title={title} description={description} schema={localBusinessSchema}>
  <Header />
  <main>
    <section class="hero hero--kinetic">
      <canvas class="hero-interactive-glass" data-hero-glass aria-hidden="true"></canvas>
      <div class="container hero__inner">
        <div class="hero__content">
          <p class="eyebrow">Termopaneles - PVC - Vidrios</p>
          <h1>Ventanas que aislan. Instalacion que responde.</h1>
          <p class="lede">
            Medimos, fabricamos e instalamos soluciones de vidrio para casas y ampliaciones en toda la Region Metropolitana. Fuera de la RM se conversa por WhatsApp.
          </p>
          <div class="button-row">
            <a class="button button--primary" href={whatsappHref()} target="_blank" rel="noreferrer">Cotizar por WhatsApp</a>
            <a class="button button--ghost" href="#obras">Ver trabajos</a>
          </div>
          <ul class="hero-proof">
            <li>Menos ruido exterior</li>
            <li>Mejor control de temperatura</li>
            <li>Materiales con marcas reconocibles</li>
            <li>Instalacion en terreno</li>
          </ul>
        </div>
        <div class="glass-stage" aria-hidden="true">
          <div class="glass-stage__frame">
            <span class="glass-pane glass-pane--one"></span>
            <span class="glass-pane glass-pane--two"></span>
            <span class="glass-pane glass-pane--three"></span>
            <span class="glass-line glass-line--one"></span>
            <span class="glass-line glass-line--two"></span>
            <span class="measure measure--top">RM completa</span>
            <span class="measure measure--side">PVC + termopanel</span>
          </div>
          <div class="quote-ticket">
            <span>Cotizacion directa</span>
            <strong>{contact.phoneDisplay}</strong>
            <small>Fotos + medidas + comuna</small>
          </div>
        </div>
      </div>
    </section>

    <TrustStrip />

    <section class="section section--paper">
      <div class="container">
        <CoverageMap />
      </div>
    </section>

    <section id="obras" class="section">
      <div class="container">
        <div class="section-grid">
          <div class="section-heading">
            <p class="eyebrow">01 - Trabajos</p>
            <h2>Obras visibles antes de pedir una cotizacion.</h2>
          </div>
          <div class="section-copy">
            <p class="lede">
              La decision se toma mirando instalaciones reales: terminaciones, perfiles, escala y cuidado en obra. Esta galeria queda lista para crecer con fotos de casas, ampliaciones, shower doors y despachos.
            </p>
            <div class="button-row">
              <a class="button button--secondary" href="/galeria/">Ver galeria</a>
              <a class="button button--primary" href={whatsappHref('Hola, quiero cotizar una instalacion similar a las obras de ItGlass')} target="_blank" rel="noreferrer">Cotizar por WhatsApp</a>
            </div>
          </div>
        </div>
        <div class="work-grid">
          {works.map((work) => <WorkCard work={work} />)}
        </div>
      </div>
    </section>

    <section id="servicios" class="section section--paper">
      <div class="container">
        <div class="section-grid">
          <div class="section-heading">
            <p class="eyebrow">02 - Servicios</p>
            <h2>El material correcto segun clima, ruido, presupuesto y uso.</h2>
          </div>
          <div class="section-copy">
            <p class="lede">
              No todas las ventanas resuelven el mismo problema. ItGlass ayuda a elegir entre PVC, aluminio, termopanel o vidrio templado con criterio tecnico y presupuesto aterrizado.
            </p>
          </div>
        </div>
        <div class="service-grid">
          {services.map((service) => <ServiceCard service={service} />)}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-grid">
          <div class="section-heading">
            <p class="eyebrow">03 - Aprende antes de cotizar</p>
            <h2>Guias para elegir sin comprar a ciegas.</h2>
          </div>
          <div class="section-copy">
            <p class="lede">
              Termopanel, grosor de vidrio, PVC o aluminio: respuestas practicas para que la conversacion por WhatsApp parta con mejor informacion.
            </p>
            <div class="button-row">
              <a class="button button--secondary" href="/blog/">Ver blog</a>
              <a class="button button--ghost" href="/preguntas-frecuentes/">Preguntas frecuentes</a>
            </div>
          </div>
        </div>
        <div class="blog-grid blog-grid--home">
          {posts.map((post) => <BlogCard post={post} />)}
        </div>
        <div class="home-faq-strip">
          <FAQList faqs={faqs} compact />
        </div>
      </div>
    </section>

    <section class="section section--navy">
      <div class="container">
        <div class="section-grid">
          <div class="section-heading">
            <p class="eyebrow">04 - Confianza</p>
            <h2>Termopanel bien instalado: confort primero, vidrio despues.</h2>
          </div>
          <div class="section-copy">
            <p class="lede">
              El termopanel funciona cuando la medicion, el perfil, el sello y la instalacion trabajan juntos. El ahorro, la baja de ruido y la condensacion dependen de esa combinacion, no solo del vidrio.
            </p>
          </div>
        </div>
        <div class="proof-grid">
          <div class="proof-panel">
            <strong>01</strong>
            <h3>Aislacion</h3>
            <p class="muted">Camara sellada y perfil correcto para reducir intercambio de temperatura entre interior y exterior.</p>
          </div>
          <div class="proof-panel">
            <strong>02</strong>
            <h3>Ruido</h3>
            <p class="muted">La composicion del vidrio y el sello ayudan a bajar ruido percibido; la ficha tecnica define el rendimiento exacto.</p>
          </div>
          <div class="proof-panel">
            <strong>03</strong>
            <h3>Durabilidad</h3>
            <p class="muted">Una instalacion prolija protege el sello, evita filtraciones y mantiene la ventana alineada en el tiempo.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container split-panel">
        <div class="split-panel__main">
          <p class="eyebrow">Negocio familiar</p>
          <h2>Atencion directa con Jaime y equipo.</h2>
          <p class="lede" style="margin-top: 22px;">
            ItGlass separa la cotizacion generica del trabajo serio: visita, medicion, recomendacion de material y conversacion clara por WhatsApp antes de fabricar.
          </p>
          <dl class="fact-list">
            <div>
              <dt>Direccion</dt>
              <dd>{contact.address}</dd>
            </div>
            <div>
              <dt>Horario</dt>
              <dd>{contact.hours}</dd>
            </div>
            <div>
              <dt>Cobertura</dt>
              <dd>Toda la Region Metropolitana. Fuera de la RM se conversa segun distancia y proyecto.</dd>
            </div>
          </dl>
        </div>
        <div class="split-panel__side">
          <p class="eyebrow">Fuera de la RM</p>
          <h3>Se conversa segun distancia y tipo de proyecto.</h3>
          <p class="muted" style="margin-top: 16px;">Si la obra esta fuera de la Region Metropolitana, envia ubicacion, fotos y medidas por WhatsApp para revisar factibilidad.</p>
          <div class="button-row" style="margin-top: 28px;">
            <a class="button button--primary" href={whatsappHref('Hola, quiero cotizar fuera de la RM y revisar factibilidad')} target="_blank" rel="noreferrer">Consultar factibilidad</a>
          </div>
        </div>
      </div>
    </section>

    <section class="contact-band">
      <div class="container contact-band__inner">
        <div class="contact-band__copy">
          <p class="eyebrow">Cotizacion directa</p>
          <h2>Envia medidas, fotos o ubicacion por WhatsApp.</h2>
        </div>
        <div class="contact-band__action">
          <a class="button button--secondary" href={whatsappHref()} target="_blank" rel="noreferrer">{contact.phoneDisplay}</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppButton />
</BaseLayout>

<script>
  const heroCanvas = document.querySelector('[data-hero-glass]');
  const hero = heroCanvas?.closest('.hero');

  if (heroCanvas instanceof HTMLCanvasElement && hero && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const ctx = heroCanvas.getContext('2d');
    const pointer = { x: 0.68, y: 0.42, tx: 0.68, ty: 0.42, active: 0 };
    let width = 0;
    let height = 0;
    let dpr = 1;
    let raf = 0;
    let idleTimer = 0;

    const resize = () => {
      const rect = hero.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = Math.max(1, Math.round(rect.width));
      height = Math.max(1, Math.round(rect.height));
      heroCanvas.width = Math.round(width * dpr);
      heroCanvas.height = Math.round(height * dpr);
      heroCanvas.style.width = `${width}px`;
      heroCanvas.style.height = `${height}px`;
      ctx?.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const movePointer = (clientX: number, clientY: number) => {
      const rect = hero.getBoundingClientRect();
      pointer.tx = Math.min(1, Math.max(0, (clientX - rect.left) / rect.width));
      pointer.ty = Math.min(1, Math.max(0, (clientY - rect.top) / rect.height));
      pointer.active = 1;
      window.clearTimeout(idleTimer);
      idleTimer = window.setTimeout(() => {
        pointer.active = 0;
      }, 1100);
    };

    const draw = (time: number) => {
      if (!ctx) return;

      pointer.x += (pointer.tx - pointer.x) * 0.1;
      pointer.y += (pointer.ty - pointer.y) * 0.1;

      ctx.clearRect(0, 0, width, height);
      const px = pointer.x * width;
      const py = pointer.y * height;
      const pulse = 0.62 + Math.sin(time * 0.0024) * 0.16 + pointer.active * 0.28;

      const glow = ctx.createRadialGradient(px, py, 0, px, py, Math.max(width, height) * 0.38);
      glow.addColorStop(0, `rgba(255, 255, 255, ${0.1 + pointer.active * 0.08})`);
      glow.addColorStop(0.12, `rgba(223, 194, 159, ${0.14 + pointer.active * 0.06})`);
      glow.addColorStop(0.34, 'rgba(96, 143, 174, 0.08)');
      glow.addColorStop(1, 'rgba(0, 16, 38, 0)');
      ctx.fillStyle = glow;
      ctx.fillRect(0, 0, width, height);

      ctx.lineWidth = 1;
      for (let i = -1; i < 8; i++) {
        const x = (i / 7) * width;
        ctx.strokeStyle = `rgba(253, 251, 247, ${0.035 + pulse * 0.015})`;
        ctx.beginPath();
        ctx.moveTo(x, 0);
        ctx.lineTo(x - 10, height);
        ctx.stroke();
      }

      for (let i = 0; i < 6; i++) {
        const y = (i / 5) * height;
        ctx.strokeStyle = 'rgba(253, 251, 247, 0.032)';
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(width, y + 8);
        ctx.stroke();
      }

      const panes = [
        [0.58, 0.34, 0.25, 0.28, -0.2],
        [0.72, 0.57, 0.24, 0.34, 0.18],
        [0.45, 0.68, 0.23, 0.24, -0.34],
      ];

      ctx.globalCompositeOperation = 'screen';

      panes.forEach(([x, y, w, h, refraction], index) => {
        const paneX = x * width;
        const paneY = y * height;
        const paneW = w * width;
        const paneH = h * height;
        const centerX = paneX + paneW / 2;
        const centerY = paneY + paneH / 2;
        const distance = Math.hypot(centerX - px, centerY - py);
        const shine = Math.max(0, 1 - distance / Math.max(width * 0.62, 240));
        const localX = (px - paneX) / paneW - 0.5;
        const localY = (py - paneY) / paneH - 0.5;
        const bend = (localX * 0.72 - localY * 0.34 + refraction) * paneW;
        const drop = (localY * 0.4 - refraction * 0.24) * paneH;
        ctx.strokeStyle = `rgba(253, 251, 247, ${0.11 + shine * 0.18})`;
        ctx.fillStyle = `rgba(253, 251, 247, ${0.025 + index * 0.006})`;
        ctx.beginPath();
        ctx.rect(paneX, paneY, paneW, paneH);
        ctx.fill();
        ctx.stroke();

        ctx.save();
        ctx.beginPath();
        ctx.rect(paneX, paneY, paneW, paneH);
        ctx.clip();

        const reflectGradient = ctx.createLinearGradient(paneX, paneY + paneH, paneX + paneW, paneY);
        reflectGradient.addColorStop(0, 'rgba(255, 255, 255, 0)');
        reflectGradient.addColorStop(0.38, 'rgba(255, 255, 255, 0.06)');
        reflectGradient.addColorStop(0.5, `rgba(255, 255, 255, ${0.15 + shine * 0.42 + pointer.active * 0.08})`);
        reflectGradient.addColorStop(0.62, 'rgba(223, 194, 159, 0.12)');
        reflectGradient.addColorStop(1, 'rgba(255, 255, 255, 0)');
        ctx.strokeStyle = reflectGradient;
        ctx.lineWidth = 2.4 + shine * 3.2;
        ctx.lineCap = 'round';
        ctx.beginPath();
        ctx.moveTo(paneX - paneW * 0.22 + bend * 0.18, paneY + paneH * 1.1 + drop);
        ctx.bezierCurveTo(
          paneX + paneW * 0.18 + bend * 0.45,
          paneY + paneH * 0.78 + drop * 0.4,
          paneX + paneW * 0.58 + bend * 0.18,
          paneY + paneH * 0.42 - drop * 0.12,
          paneX + paneW * 1.16 + bend * -0.22,
          paneY - paneH * 0.14 - drop * 0.28
        );
        ctx.stroke();

        ctx.strokeStyle = `rgba(255, 255, 255, ${0.05 + shine * 0.18})`;
        ctx.lineWidth = 1.2;
        ctx.beginPath();
        ctx.moveTo(paneX + paneW * 0.2 - bend * 0.1, paneY + paneH * 0.98);
        ctx.quadraticCurveTo(
          paneX + paneW * 0.52 + bend * 0.24,
          paneY + paneH * 0.5 + drop * 0.18,
          paneX + paneW * 0.86 + bend * 0.08,
          paneY + paneH * 0.1
        );
        ctx.stroke();
        ctx.restore();
      });

      const beam = ctx.createRadialGradient(px, py, 0, px, py, Math.max(width, height) * 0.14);
      beam.addColorStop(0, 'rgba(255, 255, 255, 0)');
      beam.addColorStop(0.42, `rgba(255, 255, 255, ${0.07 + pointer.active * 0.07})`);
      beam.addColorStop(1, 'rgba(255, 255, 255, 0)');
      ctx.fillStyle = beam;
      ctx.fillRect(0, 0, width, height);

      const sparkle = ctx.createRadialGradient(px, py, 0, px, py, 22 + pointer.active * 10);
      sparkle.addColorStop(0, `rgba(255, 255, 255, ${0.3 + pointer.active * 0.14})`);
      sparkle.addColorStop(0.3, 'rgba(223, 194, 159, 0.14)');
      sparkle.addColorStop(1, 'rgba(255, 255, 255, 0)');
      ctx.fillStyle = sparkle;
      ctx.fillRect(0, 0, width, height);
      ctx.globalCompositeOperation = 'source-over';

      raf = window.requestAnimationFrame(draw);
    };

    resize();
    window.addEventListener('resize', resize);
    hero.addEventListener('pointermove', (event) => movePointer(event.clientX, event.clientY), { passive: true });
    hero.addEventListener('touchmove', (event) => {
      const touch = event.touches[0];
      if (touch) movePointer(touch.clientX, touch.clientY);
    }, { passive: true });
    hero.addEventListener('pointerleave', () => {
      pointer.active = 0;
    });

    raf = window.requestAnimationFrame(draw);
    document.addEventListener('astro:before-swap', () => {
      window.cancelAnimationFrame(raf);
      window.clearTimeout(idleTimer);
    }, { once: true });
  }
</script>
